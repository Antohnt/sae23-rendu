    },
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "type": "graph",
        "title": "Temperature",
        "datasource": "InfluxDB",
        "targets": [
          {
            "groupBy": [
              { "params": ["$__interval"], "type": "time" },
              { "params": ["room"], "type": "tag" },
              { "params": ["null"], "type": "fill" }
            ],
            "measurement": "temperature",
            "orderByTime": "ASC",
            "policy": "default",
            "refId": "A",
            "resultFormat": "time_series",
            "select": [[
              { "params": ["value"], "type": "field" },
              { "params": [], "type": "mean" }
            ]],
            "tags": [
              { "key": "room", "operator": "=~", "value": "/^$room$/" },
              { "condition": "AND", "key": "building", "operator": "=~", "value": "/^$building$/" }
            ]
          }
        ],
        "yaxes": [
          { "format": "celsius", "label": "°C", "show": true },
          { "format": "short", "show": false }
        ],
        "lines": true,
        "linewidth": 2,
        "fill": 1,
        "legend": { "show": true, "avg": true, "max": true, "min": true, "values": true }
