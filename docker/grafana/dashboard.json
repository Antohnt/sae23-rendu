          "includeAll": true,
          "multi": true,
          "name": "room",
          "query": "SHOW TAG VALUES FROM temperature WITH KEY = \"room\"",
          "refresh": 1,
          "type": "query",
          "label": "Salle"
        },
        {
          "allValue": null,
